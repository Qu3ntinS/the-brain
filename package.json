{
  "name": "the-brain",
  "version": "1.0.50",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:services": "bash scripts/dev-services.sh",
    "dev:down": "docker compose down",
    "dev:api": "bun run --watch src/index.ts",
    "dev:web": "bun run --cwd web dev",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun run src/database/seed-cli.ts",
    "db:studio": "drizzle-kit studio",
    "start": "bun run db:seed && bun run src/index.ts",
    "build:web": "bun run --cwd web build",
    "build": "bun run build:web",
    "generate:logo": "python3 scripts/build-logo.py",
    "test": "bun test test/ --preload ./test/preload.ts",
    "test:web": "bun run --cwd web test"
  },
  "overrides": {
    "elysia": "1.4.29"
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.4",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/eden": "^1.4.9",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "@elysiajs/static": "^1.4.10",
    "drizzle-orm": "^0.45.2",
    "elysia": "1.4.29",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "bun-types": "latest",
    "drizzle-kit": "^0.31.10"
  },
  "module": "src/index.js"
}
