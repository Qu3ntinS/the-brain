{
  "name": "the-brain",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun run dev:api & bun run dev:web",
    "dev:api": "bun run --watch src/index.ts",
    "dev:web": "bun run --cwd web dev",
    "start": "bun run src/index.ts",
    "build:web": "bun run --cwd web build",
    "build": "bun run build:web",
    "generate:logo": "python3 scripts/build-logo.py",
    "test": "bun test test/",
    "test:web": "bun run --cwd web test"
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.4",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "@elysiajs/static": "^1.4.10",
    "elysia": "latest"
  },
  "devDependencies": {
    "bun-types": "latest"
  },
  "module": "src/index.js"
}
