# Required
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_PASSWORD=change-me

# Optional — seeds the initial admin user in Postgres (see db:seed)
PORT=3000
ADMIN_USERNAME=admin
JWT_EXPIRES_IN=7d

# Docker dev services (docker compose)
POSTGRES_USER=brain
POSTGRES_PASSWORD=brain
POSTGRES_DB=brain
POSTGRES_PORT=5432
ADMINER_PORT=8080
MAILPIT_WEB_PORT=18025
MAILPIT_SMTP_PORT=11025

# App database + mail (defaults match docker compose above)
DATABASE_URL=postgres://brain:brain@localhost:5432/brain
SMTP_HOST=localhost
SMTP_PORT=11025
MAILPIT_WEB_URL=http://localhost:18025
